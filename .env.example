# ── Application configuration ───────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── Gemini API configuration (REQUIRED for chat) ────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── JWT Signing Key ─────────────────────────────────────────
# Change this in production! Generate with: openssl rand -hex 32
JWT_SECRET_KEY=c391bb16b47c01b17b6dc1839e1ff9e3dfa77e8a93abfae9834190c10b77b102

# ── PostgreSQL Database URL ─────────────────────────────────
# For docker deployment, this is overridden in docker-compose.yml
DATABASE_URL=postgresql+asyncpg://legalsense:legalsense@localhost:5432/legalsense

# ── Qdrant Vector Store configuration ───────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=legal_sections

# ── Provider-agnostic LLM Layer (options: gemini, openai, anthropic, ollama, azure_openai) ──
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# ── Other LLM Provider Keys (uncomment & fill if switching) ────
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
# OLLAMA_BASE_URL=http://localhost:11434
# AZURE_OPENAI_API_KEY=your_azure_key
# AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com
